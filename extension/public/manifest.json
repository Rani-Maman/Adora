{
    "manifest_version": 3,
    "key": "",
    "name": "Adora - Dropship Detector",
    "version": "1.0.0",
    "description": "Warns you when visiting potential dropshipping sites in Israel",
    "permissions": [
        "activeTab",
        "storage",
        "identity"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": ["icons/*"],
            "matches": ["http://*/*", "https://*/*"]
        }
    ]
}